// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

CARLITO_CODE_SIGN_STYLE = Automatic
CARLITO_DEVELOPMENT_TEAM = YOUR_TEAM_ID

CARLITO_APP_BUNDLE_ID = ai.carlito.client
CARLITO_SHARE_BUNDLE_ID = ai.carlito.client.share
CARLITO_ACTIVITY_WIDGET_BUNDLE_ID = ai.carlito.client.activitywidget
CARLITO_WATCH_APP_BUNDLE_ID = ai.carlito.client.watchkitapp
CARLITO_WATCH_EXTENSION_BUNDLE_ID = ai.carlito.client.watchkitapp.extension

// Leave empty with automatic signing.
CARLITO_APP_PROFILE =
CARLITO_SHARE_PROFILE =
CARLITO_WATCH_APP_PROFILE =
CARLITO_WATCH_EXTENSION_PROFILE =
