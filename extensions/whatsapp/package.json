{
  "name": "@realcarlossanchez101/whatsapp",
  "version": "2026.4.20",
  "description": "Carlito WhatsApp channel plugin",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "jimp": "^1.6.1",
    "typebox": "1.1.28",
    "undici": "8.1.0"
  },
  "devDependencies": {
    "@realcarlossanchez101/plugin-sdk": "workspace:*",
    "carlito": "workspace:*"
  },
  "peerDependencies": {
    "carlito": ">=2026.4.24"
  },
  "peerDependenciesMeta": {
    "carlito": {
      "optional": true
    }
  },
  "carlito": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "setupFeatures": {
      "legacyStateMigrations": true,
      "legacySessionSurfaces": true
    },
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message",
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyWhatsAppAuth"
      },
      "cliAddOptions": [
        {
          "flags": "--auth-dir <path>",
          "description": "WhatsApp auth directory override"
        }
      ]
    },
    "install": {
      "npmSpec": "@realcarlossanchez101/whatsapp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.24"
    },
    "compat": {
      "pluginApi": ">=2026.4.24"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "build": {
      "carlitoVersion": "2026.4.20"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
