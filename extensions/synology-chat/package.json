{
  "name": "@realcarlossanchez101/synology-chat",
  "version": "2026.4.20",
  "description": "Synology Chat channel plugin for Carlito",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@realcarlossanchez101/plugin-sdk": "workspace:*"
  },
  "carlito": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to Carlito with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@realcarlossanchez101/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
