{
  "name": "@realcarlossanchez101/qqbot",
  "version": "2026.4.20",
  "private": false,
  "description": "Carlito QQ Bot channel plugin",
  "type": "module",
  "dependencies": {
    "@tencent-connect/qqbot-connector": "^1.1.0",
    "mpg123-decoder": "^1.0.3",
    "silk-wasm": "^3.7.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@realcarlossanchez101/plugin-sdk": "workspace:*",
    "@types/ws": "^8.18.1",
    "carlito": "workspace:*"
  },
  "peerDependencies": {
    "carlito": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "carlito": {
      "optional": true
    }
  },
  "carlito": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "qqbot",
      "label": "QQ Bot",
      "selectionLabel": "QQ Bot (Official API)",
      "detailLabel": "QQ Bot",
      "docsPath": "/channels/qqbot",
      "docsLabel": "qqbot",
      "blurb": "connect to QQ via official QQ Bot API with group chat and direct message support.",
      "systemImage": "bubble.left.and.bubble.right"
    },
    "install": {
      "npmSpec": "@realcarlossanchez101/qqbot",
      "localPath": "extensions/qqbot",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "carlitoVersion": "2026.4.20"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
