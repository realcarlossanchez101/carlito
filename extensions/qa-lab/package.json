{
  "name": "@realcarlossanchez101/qa-lab",
  "version": "2026.4.20",
  "private": true,
  "description": "Carlito QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "dependencies": {
    "@copilotkit/aimock": "1.14.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "playwright-core": "1.59.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@realcarlossanchez101/plugin-sdk": "workspace:*",
    "carlito": "workspace:*"
  },
  "peerDependencies": {
    "carlito": ">=2026.4.20"
  },
  "peerDependenciesMeta": {
    "carlito": {
      "optional": true
    }
  },
  "carlito": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@realcarlossanchez101/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    }
  }
}
