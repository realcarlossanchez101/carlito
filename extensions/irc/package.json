{
  "name": "@realcarlossanchez101/irc",
  "version": "2026.4.20",
  "description": "Carlito IRC channel plugin",
  "type": "module",
  "devDependencies": {
    "@realcarlossanchez101/plugin-sdk": "workspace:*"
  },
  "carlito": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.4.10"
    },
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "irc",
      "label": "IRC",
      "selectionLabel": "IRC (Server + Nick)",
      "detailLabel": "IRC",
      "docsPath": "/channels/irc",
      "docsLabel": "irc",
      "blurb": "classic IRC networks with DM/channel routing and pairing controls.",
      "aliases": [
        "internet-relay-chat"
      ],
      "systemImage": "network",
      "configuredState": {
        "specifier": "./configured-state",
        "exportName": "hasIrcConfiguredState"
      }
    }
  }
}
