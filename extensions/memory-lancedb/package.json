{
  "name": "@realcarlossanchez101/memory-lancedb",
  "version": "2026.4.20",
  "description": "Carlito LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "openai": "^6.34.0",
    "typebox": "1.1.28"
  },
  "devDependencies": {
    "@realcarlossanchez101/plugin-sdk": "workspace:*"
  },
  "carlito": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@realcarlossanchez101/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.20"
    },
    "build": {
      "carlitoVersion": "2026.4.20"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
